# ============================================
# AISHA CRM - PRODUCTION ENVIRONMENT TEMPLATE
# ============================================
# IMPORTANT: This is a TEMPLATE file - do NOT commit actual secrets!
# Copy this to .env.production.actual and fill in real values
# Use Doppler for secret management in production: doppler run --

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=production

# ============================================
# FRONTEND URLS
# ============================================
FRONTEND_URL=https://your-domain.com
ALLOWED_ORIGINS=https://your-domain.com
VITE_AISHACRM_BACKEND_URL=https://your-domain.com/api

# ============================================
# DATABASE (Supabase)
# ============================================
USE_SUPABASE_PROD=true
SUPABASE_URL=https://your-project.supabase.co
# CRITICAL: Get from Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME_SUPABASE_SERVICE_ROLE_KEY
# Public anon key (safe to expose in frontend)
SUPABASE_ANON_KEY=CHANGE_ME_SUPABASE_ANON_KEY
SUPABASE_STORAGE_BUCKET=tenant-assets
DB_SSL=true

# PostgreSQL connection string (if needed)
DATABASE_URL=postgresql://postgres:CHANGE_ME_DB_PASSWORD@db.your-project.supabase.co:5432/postgres?sslmode=require

# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=CHANGE_ME_SUPABASE_ANON_KEY
VITE_SUPABASE_PUBLISHABLE_KEY=CHANGE_ME_SUPABASE_ANON_KEY

# ============================================
# SECURITY & AUTHENTICATION
# ============================================
# Generate with: openssl rand -base64 32
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_32_CHARS_MIN
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_JWT_SECRET_128_CHARS_RECOMMENDED
# Optional: Set if using subdomains (e.g., .your-domain.com)
# COOKIE_DOMAIN=.your-domain.com

# ============================================
# INTRUSION DETECTION & RESPONSE (IDR)
# ============================================
IDR_ENABLED=false
IDR_DEBUG=false
# Comma-separated IPs/CIDR ranges to whitelist
IDR_WHITELIST_IPS=your.vps.ip.address
# Generate with: openssl rand -hex 32
IDR_EMERGENCY_SECRET=CHANGE_ME_EMERGENCY_UNBLOCK_SECRET

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=500

# ============================================
# PRODUCTION SAFETY GUARDS
# ============================================
PRODUCTION_SAFETY_GUARD_ENABLED=false
ALLOW_PRODUCTION_WRITES=true

# ============================================
# REDIS CONNECTIONS
# ============================================
REDIS_MEMORY_URL=redis://redis-memory:6379
REDIS_CACHE_URL=redis://redis-cache:6379

# ============================================
# BRAID MCP SERVER
# ============================================
# Generate with: openssl rand -base64 24
MCP_SECRET=CHANGE_ME_MCP_SECRET
MCP_PORT=4002
CRM_BACKEND_URL=http://aishacrm-backend:3001
USE_DIRECT_SUPABASE_ACCESS=true

# ============================================
# SYSTEM LOGS & BATCHING
# ============================================
VITE_SYSTEM_LOG_LEVEL=ERROR
VITE_SYSTEM_LOG_BATCH_INTERVAL_MS=2000
VITE_SYSTEM_LOG_MAX_BATCH=25

# ============================================
# HEARTBEATS
# ============================================
VITE_USER_HEARTBEAT_INTERVAL_MS=90000
HEARTBEAT_INTERVAL_MS=120000
HEARTBEAT_ENABLED=true

# ============================================
# N8N AUTOMATION (Optional)
# ============================================
N8N_USER=your-email@example.com
N8N_PASSWORD=CHANGE_ME_N8N_PASSWORD
# N8N_HOST=localhost
# N8N_WEBHOOK_URL=http://localhost:5678

# ============================================
# OPENAI (AI Features)
# ============================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-CHANGE_ME_OPENAI_API_KEY

# ============================================
# EMAIL/SMS (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=CHANGE_ME_SMTP_PASSWORD
# TWILIO_ACCOUNT_SID=CHANGE_ME
# TWILIO_AUTH_TOKEN=CHANGE_ME

# ============================================
# SECURITY NOTES
# ============================================
# ⚠️  NEVER commit actual secrets to git!
# ✅  Use Doppler for production: doppler run -- npm start
# ✅  Use GitHub Secrets for CI/CD pipelines
# ✅  Rotate secrets if ever exposed
# ✅  Keep .env.production.actual in .gitignore
