// Executive Assistant Tools - DocuSeal e-Signature
// Send documents for signature, list available templates, track submission status
//
// 4VD-10: Exposes the existing /api/docuseal/* routes to AiSHA so users can say
// things like "Send the NDA to this lead" in chat. The CRM-side routes already
// enforce tenant isolation via external_id (4VD-15), so these wrappers don't
// need extra security — they just relay calls.

import { Result, CRMError } from "../../spec/types.braid"

// Error handling: HTTP errors return CRMError with APIError tag and status code.
// The backend interprets status codes to determine error type.

@policy(READ_ONLY)
fn listDocusealTemplates(
  tenant_id: String
) -> Result<Array, CRMError> !net {
  // Returns templates available to THIS tenant (filtered server-side via
  // external_id=tenant_id from 4VD-15). Useful for the LLM to pick the right
  // template by name when the user says "send the NDA".
  let url = "/api/docuseal/templates";
  let params = { tenant_id: tenant_id };

  let response = http.get(url, { params: params });

  // Empty array is a VALID result (tenant has no templates yet) — not an error.
  return match response {
    Ok{value} => Ok(value.data),
    Err{error} => Err({ tag: "APIError", url: url, code: error.status, operation: "list_docuseal_templates" }),
    _ => Err({ tag: "NetworkError", url: url, code: 500 })
  };
}

@policy(READ_ONLY)
fn listDocusealSubmissions(
  tenant_id: String,
  entity_type: String,
  entity_id: String
) -> Result<Array, CRMError> !net {
  // Returns submissions linked to a specific CRM entity (lead/contact/account/opportunity).
  // entity_type maps to the API's `related_to` field; entity_id maps to `related_id`.
  // Use this when the user asks "what documents are out for signature on this lead?"
  let url = "/api/docuseal/submissions";
  let params = {
    tenant_id: tenant_id,
    related_to: entity_type,
    related_id: entity_id
  };

  let response = http.get(url, { params: params });

  // Empty array is a VALID result (no docs sent for this entity yet) — not an error.
  return match response {
    Ok{value} => Ok(value.data),
    Err{error} => Err({ tag: "APIError", url: url, code: error.status, operation: "list_docuseal_submissions" }),
    _ => Err({ tag: "NetworkError", url: url, code: 500 })
  };
}

@policy(WRITE_OPERATIONS)
fn sendDocumentForSigning(
  tenant_id: String,
  template_id: String,
  entity_type: String,
  entity_id: String,
  recipient_email: String,
  recipient_name: String,
  message: String
) -> Result<Object, CRMError> !net {
  // Send a document for signature. The backend creates a DocuSeal submission,
  // sends a tenant-branded email to the recipient, and inserts a tracking row.
  //
  // entity_type/entity_id maps to related_to/related_id on the submission row,
  // which lets the CRM render the document on the entity's activity timeline
  // and link the eventual signed PDF back to the entity.
  //
  // The 4VD-34 cache resolver populates template_name from the per-tenant
  // dropdown cache, so the activity will read "Document sent — NDA" instead
  // of "unnamed template".
  let url = "/api/docuseal/submissions";
  let payload = {
    tenant_id: tenant_id,
    template_id: template_id,
    related_to: entity_type,
    related_id: entity_id,
    recipient_email: recipient_email,
    recipient_name: recipient_name,
    message: message
  };

  let response = http.post(url, { body: payload });

  return match response {
    Ok{value} => Ok(value.data),
    Err{error} => Err({ tag: "APIError", url: url, code: error.status, operation: "send_document_for_signing" }),
    _ => Err({ tag: "NetworkError", url: url, code: 500 })
  };
}
