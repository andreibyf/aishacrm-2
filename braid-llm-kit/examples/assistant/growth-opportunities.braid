// Executive Assistant Tools - Growth / Opportunity Intelligence
// OSINT market & demand intelligence: read scored, DIRECTIONAL growth
// opportunities, the current persisted insight, and kick off a new insight run.
//
// NOTE: the internal entity is `growth_opportunities` (NOT `opportunities` — the
// sales pipeline owns that word). UI copy says "Opportunities". All output is
// DIRECTIONAL ("interest rising/falling") — never raw keyword counts or invented
// percentages.

import { Result, CRMError } from "../../spec/types.braid"

@policy(READ_ONLY)
fn getTopGrowthOpportunities(
  tenant_id: String,
  limit: Number,
  opportunity_type: String
) -> Result<Array, CRMError> !net {
  let url = "/api/v2/growth/opportunities";
  let params = {
    tenant_id: tenant_id,
    limit: limit,
    category: opportunity_type
  };

  let response = http.get(url, { params: params });

  return match response {
    Ok{value} => Ok(value.data),
    Err{error} => CRMError.fromHTTP(url, error.status, "get_top_growth_opportunities"),
    _ => CRMError.network(url, 500, "unknown")
  };
}

@policy(READ_ONLY)
fn getGrowthOpportunityDetail(
  tenant_id: String,
  opportunity_id: String
) -> Result<Object, CRMError> !net {
  let url = "/api/v2/growth/opportunities/" + opportunity_id;
  let params = { tenant_id: tenant_id };

  let response = http.get(url, { params: params });

  return match response {
    Ok{value} => Ok(value.data),
    Err{error} => CRMError.fromHTTP(url, error.status, "get_growth_opportunity_detail"),
    _ => CRMError.network(url, 500, "unknown")
  };
}

