@policy(WRITE_OPERATIONS)
fn requestInsightRun(
  tenant_id: String
) -> Result<Object, CRMError> !net {
  // Kicks off an async insight run (subject to the once-per-7-days throttle;
  // superadmin is exempt). Returns { id, status:'running', eta_seconds, eta_range }
  // on 202, or an APIError with code 429 when throttled.
  let url = "/api/v2/growth/insights";
  let body = { tenant_id: tenant_id };

  let response = http.post(url, { body: body });

  return match response {
    Ok{value} => Ok(value.data),
    Err{error} => CRMError.fromHTTP(url, error.status, "request_insight_run"),
    _ => CRMError.network(url, 500, "unknown")
  };
}

@policy(WRITE_OPERATIONS)
fn actionGrowthOpportunity(
  tenant_id: String,
  opportunity_id: String,
  overrides: Object
) -> Result<Object, CRMError> !net {
  let url = "/api/v2/growth/opportunities/" + opportunity_id + "/action";
  let body = {
    tenant_id: tenant_id,
    overrides: overrides
  };

  let response = http.post(url, { body: body });

  return match response {
    Ok{value} => Ok(value.data),
    Err{error} => CRMError.fromHTTP(url, error.status, "action_growth_opportunity"),
    _ => CRMError.network(url, 500, "unknown")
  };
}

@policy(WRITE_OPERATIONS)
fn dismissGrowthOpportunity(
  tenant_id: String,
  opportunity_id: String,
  reason: String
) -> Result<Object, CRMError> !net {
  let url = "/api/v2/growth/opportunities/" + opportunity_id + "/dismiss";
  let body = {
    tenant_id: tenant_id,
    reason: reason
