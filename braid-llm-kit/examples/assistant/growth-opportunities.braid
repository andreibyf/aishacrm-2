  let response = http.post(url, { body: body });

  return match response {
    Ok{value} => Ok(value.data),
    Err{error} => CRMError.fromHTTP(url, error.status, "dismiss_growth_opportunity"),
    _ => CRMError.network(url, 500, "unknown")
