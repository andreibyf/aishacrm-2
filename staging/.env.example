# Staging environment variables — set these per Coolify resource
# (Coolify UI → Application → Environment Variables)
#
# Most secrets are pulled at runtime via Doppler stg_stg config.
# These are the values Coolify itself substitutes into docker-compose.yml.

# === ALL GROUPS ===
DOPPLER_TOKEN=                    # Service token for stg_stg config (required)
DOPPLER_PROJECT=aishacrm
DOPPLER_CONFIG=stg_stg

# === Image tags (default: latest) ===
# Pin to a specific tag in Coolify when promoting a known-good build to staging.
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest
LITELLM_IMAGE_TAG=latest
MCP_IMAGE_TAG=latest

# === Group 1: backend-heavy ===
# Phase 1 (Redis only): leave COMPOSE_PROFILES unset
# Phase 2+ (backend joins): set COMPOSE_PROFILES=app
COMPOSE_PROFILES=
ALLOWED_ORIGINS=https://staging-app.aishacrm.com
PUBLIC_SCHEDULER_URL=https://staging-scheduler.aishacrm.com

# === Group 2: app-fast ===
# OpenReplay is excluded from this deployment split — leave keys blank to disable.
VITE_OPENREPLAY_PROJECT_KEY=
VITE_OPENREPLAY_INGEST_POINT=
VITE_OPENREPLAY_DASHBOARD_URL=https://replay.aishacrm.com
COMMUNICATIONS_WORKER_POLL_INTERVAL_MS=60000

# === Group 4: braid ===
DEFAULT_TENANT_ID=a11dfb63-4b18-4eb8-872e-747af2e37c46

# === Group 5: scheduling-rare ===
# All values below MUST be present in Doppler stg_stg AND surfaced as Coolify env vars
# because Cal.com is a plain image (no Doppler CLI inside the container).
CALCOM_DB_USER=calcom
CALCOM_DB_PASSWORD=                          # Required — generate fresh, do NOT reuse prod
CALCOM_DB_NAME=calcom
CALCOM_NEXTAUTH_SECRET=                      # 32+ char random — required
CALCOM_ENCRYPTION_KEY=                       # 32 char random — required
CALCOM_PUBLIC_URL=https://staging-scheduler.aishacrm.com
CALCOM_ALLOWED_HOSTNAMES="staging-scheduler.aishacrm.com"
CALCOM_LICENSE_KEY=59c0bed7-8b21-4280-8514-e022fbfc24c7
CALCOM_EMAIL_FROM=noreply@aishacrm.com
CALCOM_SMTP_HOST=
CALCOM_SMTP_PORT=587
CALCOM_SMTP_USER=
CALCOM_SMTP_PASSWORD=
