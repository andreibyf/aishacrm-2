# Environment variables for VPS-2 services
# Copy this to /opt/aishacrm/.env on VPS-2

# Cal.com Database
CALCOM_DB_USER=calcom
CALCOM_DB_PASSWORD=<get-from-doppler>
CALCOM_DB_NAME=calcom

# Cal.com Configuration
CALCOM_NEXTAUTH_SECRET=<get-from-doppler>
CALCOM_ENCRYPTION_KEY=<get-from-doppler>
CALCOM_PUBLIC_URL=https://scheduler.aishacrm.com
CALCOM_ALLOWED_HOSTNAMES="scheduler.aishacrm.com"

# Cal.com SMTP (for booking notifications)
CALCOM_EMAIL_FROM=noreply@aishacrm.com
CALCOM_SMTP_HOST=<get-from-doppler>
CALCOM_SMTP_PORT=587
CALCOM_SMTP_USER=<get-from-doppler>
CALCOM_SMTP_PASSWORD=<get-from-doppler>

# Hawser (get from https://dockhand.dev)
HAWSER_TOKEN=<get-from-dockhand>
